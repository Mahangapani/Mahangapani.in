# ─── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5000

# ─── JWT Auth ──────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── NewsAPI ───────────────────────────────────────────
# Free key at https://newsapi.org/register (500 req/day free)
NEWS_API_KEY=your_newsapi_key_here
NEWS_API_COUNTRY=in
NEWS_API_PAGE_SIZE=30

# ─── Anthropic Claude (AI summaries) ───────────────────
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Admin Account (created on first boot) ─────────────
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@mahangapani.com
ADMIN_PASSWORD=Admin@2026!

# ─── Database ──────────────────────────────────────────
# SQLite file path (relative to project root)
DB_PATH=./database/mahangapani.db

# ─── Cron Schedule ─────────────────────────────────────
# Default: top of every hour  "0 * * * *"
# Every 30 min:               "*/30 * * * *"
CRON_SCHEDULE=0 * * * *
